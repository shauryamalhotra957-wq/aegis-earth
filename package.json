{
  "name": "aegis-earth",
  "version": "1.0.0",
  "private": true,
  "description": "A public-good disaster resilience command center with explainable risk scoring, response optimization, and scenario simulation.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -b --pretty false"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^15.0.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
